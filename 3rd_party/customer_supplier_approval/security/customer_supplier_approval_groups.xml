<?xml version="1.0" encoding="utf-8"?>
<!-- Add new user group-->
<odoo>
    <record model="ir.module.category" id="module_approval_validate">
        <field name="name">Partner Approval and Validation</field>
        <field name="description">User access level for validating and approving</field>
        <field name="sequence">10</field>
    </record>

    <record model="res.groups.privilege" id="res_groups_privilege_validate_partner">
            <field name="name">Allow Validate Partner</field>
            <field name="sequence">17</field>
            <field name="category_id" ref="customer_supplier_approval.module_approval_validate"/>
    </record>

    <record model="res.groups.privilege" id="res_groups_privilege_approve_partner">
            <field name="name">Allow Approve Partner</field>
            <field name="sequence">18</field>
            <field name="category_id" ref="customer_supplier_approval.module_approval_validate"/>
    </record>

    <record model="res.groups.privilege" id="res_groups_privilege_administrator">
            <field name="name">Administrator</field>
            <field name="sequence">19</field>
            <field name="category_id" ref="customer_supplier_approval.module_approval_validate"/>
    </record>

    <!--    Validation group-->
    <record id="customer_supplier_approval_group_validation" model="res.groups">
        <field name="name">Allow Validate Partner</field>
        <field name="privilege_id" ref="res_groups_privilege_validate_partner"/>
        <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <!--    Approval group-->
    <record id="customer_supplier_approval_group_approval" model="res.groups">
        <field name="name">Allow Approve Partner</field>
        <field name="privilege_id" ref="res_groups_privilege_approve_partner"/>
        <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <!--    Admin group-->
    <record id="customer_supplier_approval_group_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="res_groups_privilege_administrator"/>
        <field name="implied_ids"
               eval="[(4, ref('customer_supplier_approval.customer_supplier_approval_group_validation')),
               (4, ref('customer_supplier_approval.customer_supplier_approval_group_approval'))]"/>
    </record>
</odoo>
