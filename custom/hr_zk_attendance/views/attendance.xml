<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="hr_att_inherit_form_view" model="ir.ui.view">
        <field name="name">resource.calendar.attendance.form</field>
        <field name="model">resource.calendar.attendance</field>
        <field name="inherit_id" ref="resource.view_resource_calendar_attendance_form"/>
        <field name="arch" type="xml">
            <field name="date_to" position="after">
                <field name="late_in" widget="float_time"/>
                <field name="early_out" widget="float_time"/>
            </field>
        </field>
    </record>

    <record id="hr_att_inherit_tree_view" model="ir.ui.view">
        <field name="name">resource.calendar.attendance.tree</field>
        <field name="model">resource.calendar.attendance</field>
        <field name="inherit_id" ref="resource.view_resource_calendar_attendance_tree"/>
        <field name="arch" type="xml">
            <field name="date_to" position="after">
                <field name="late_in" widget="float_time"/>
                <field name="early_out" widget="float_time"/>
            </field>
        </field>
    </record>
    <record id="hr_att_day_inherit_tree_view" model="ir.ui.view">
        <field name="name">hr.attendance.tree</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">
            <field name="check_out" position="after">
                <field name="day_name"/>
                <field name="late_x" />
                <field name="early_x" />
                <field name="work_time_x" />
            </field>
        </field>
    </record>
    <record id="hr_att_day_inherit_form_view" model="ir.ui.view">
        <field name="name">hr.attendance.form</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <field name="check_out" position="after">
                <field name="day_name"/>
                <field name="late_x"/>
                <field name="early_x"/>
                <field name="work_time_x"/>
            </field>
        </field>
    </record>

</odoo>