<odoo>
    <data>
        <record id="internal_transfer_view" model="ir.ui.view">
            <field name="name">internal.transfer.view</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="awe_hr_employee_document.view_hr_employee_form_documents"/>
            <field name="arch" type="xml">

                <xpath expr="//page[@name='employee_documents']" position="after">
                    <page name="employee_internal_transfer" string="Internal Transfer">

                        <group>
                            <field name="internal_transfer_ids">
                                <list editable="bottom">
                                    <field name="last_department_id"/>
                                    <field name="current_department_id"/>
                                    <field name="date"/>
                                </list>
                            </field>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>