<odoo>
  <data>
     <record id="inactive_salesperson" model="ir.ui.view">
          <field name="name">Inactive salesperson</field>
          <field name="model">crm.lead</field>
          <field name="inherit_id" ref="crm.crm_lead_view_form"/>
          <field name="arch" type="xml">

            <xpath expr="//field[@name='user_id']" position="attributes">
              <attribute name="domain">[('share', '=', False),'|', ('active', '=', False), ('active', '=', True)]</attribute>
            </xpath>

          </field>
      </record>
  </data>
</odoo>