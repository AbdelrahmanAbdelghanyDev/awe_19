<odoo>
    <data>
        <record id="detailed_leave_wizard_view" model="ir.ui.view">
            <field name="name">detailed_leave_wizard_view</field>
            <field name="model">detailed.leave.excel</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="employee_ids" widget="many2many_tags"/>
                        <field name="leave_type" widget="many2many_tags"/>
                    </group>
                    <footer>
                        <button name="action_leave_report" string="Generate Report" type="object"
                                class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_detailed_leave_report" model="ir.actions.act_window">
            <field name="name">Detailed Leave Report</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">detailed.leave.excel</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_detailed_leave_report" name="Detailed Leave Report"
                  action="action_detailed_leave_report" parent="hr_holidays.menu_hr_holidays_report"
                  sequence="50"/>
    </data>
</odoo>