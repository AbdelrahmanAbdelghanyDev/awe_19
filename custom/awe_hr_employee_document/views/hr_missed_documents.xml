<?xml version="1.0"?>
<odoo>

      <record id="view_hr_missed_documents_filter_report" model="ir.ui.view">
        <field name="name">hr.missed.documents.filter</field>
        <field name="model">hr.missed.documents</field>
        <field name="arch" type="xml">
            <search string="Search Missed Documents">
<!--                <field name="code"/>-->
                <field name="employee_id"/>
                <field name="type_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee" context="{'group_by':'employee_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by':'type_id'}"/>
                    <filter name="group_company" string="Company" context="{'group_by':'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hr_missed_documents_tree" model="ir.ui.view">
        <field name="name">report.hr.missed.documents.tree</field>
        <field name="model">hr.missed.documents</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="employee_id" decoration-muted="not active_employee"/>
                <field name="active_employee" invisible="1"/>
<!--                <field name="code"/>-->
                <field name="type_id"/>
            </tree>
        </field>
    </record>

    <record id="hr_missed_documents_action" model="ir.actions.act_window">
        <field name="name">Missed Documents</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.missed.documents</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{
                'search_default_group_type': True,
            }</field>
    </record>

    <!-- This Menu Item must have a parent and an action -->
    <menuitem id="hr_missed_documents_menu" name="Missed Documents" parent="hr.menu_hr_root" groups="hr.group_hr_user" action="hr_missed_documents_action" sequence="5"/>

</odoo>
