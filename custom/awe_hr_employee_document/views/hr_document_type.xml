<odoo>
    <data>

        <record id="view_hr_document_type_form" model="ir.ui.view">
            <field name="name">View Hr Document Form</field>
            <field name="model">hr.document.type</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="sync_attachment"
                                string="Sync Attachment" class="oe_highlight"
                                type="object"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_document_type" model="ir.actions.act_window">
            <field name="name">Document Types</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hr.document.type</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="menu_hr_document_type"
                  name="Document Types"
                  parent="hr.menu_human_resources_configuration"
                  action="view_hr_document_type"
                  sequence="15"/>
    </data>
</odoo>