<odoo>
    <data>
        explicit list view definition

        <record id="receiver_system_form_view" model="ir.ui.view">
            <field name="name">receiver_system_form_view</field>
            <field name="model">receiver.system</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="server_url"/>
                        <field name="db_name"/>
                        <field name="db_user"/>
                        <field name="db_password"/>
                        <field name="syncronize"/>
                    </group>
                </form>
            </field>
        </record>


        <record id="receiver_system_tree_view" model="ir.ui.view">
            <field name="name">receiver_system_tree_view</field>
            <field name="model">receiver.system</field>
            <field name="arch" type="xml">
                <list>
                    <field name="server_url"/>
                    <field name="db_name"/>
                    <field name="db_user"/>
                    <field name="db_password"/>
                    <field name="syncronize"/>
                </list>
            </field>
        </record>


<!--        actions opening views on models-->
        <record model="ir.actions.act_window" id="receiver_system_action_window">
            <field name="name">receiver system</field>
            <field name="res_model">receiver.system</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem name="Invoice Receiver System" id="receiver_system_menu_item" parent="base.menu_custom"
                  action="receiver_system_action_window" sequence="100"/>


    </data>
</odoo>