        <!--Inherit quotations search view-->
        <record id="view_project_taskr_inherit_search" model="ir.ui.view">
            <field name="name">project.task.search.expand.filter</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_search_form"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <!-- This field will show up on the default filters
                         &lt; is the XML encoding for < and &gt; is the XML encoding for > -->
                    <filter string="Today" name="today" domain="[('today_flag', '=', True)]"/>

                </xpath>
            </field>
        </record>


        <!-- explicit list view definition -->
        <record model="ir.ui.view" id="custom_project_list_view">
            <field name="name">custom.project.list.view</field>
            <field name="model">project.task.teams</field>
            <field name="arch" type="xml">
                <list string='List Details'>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- actions opening views on models -->
        <record id="custom_project_template_action" model="ir.actions.act_window">
            <field name="name">Teams</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">project.task.teams</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to define a new Team.
                </p>
            </field>
        </record>

        <!-- explicit Form view definition -->
        <record id="custom_project_details_form_view" model="ir.ui.view">
            <field name="name">project.task.teams.form</field>
            <field name="model">project.task.teams</field>
            <field name="arch" type="xml">
                <form string="_form">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="member_ids"/>
                        </group>

                        <div class="oe_chatter">
                            <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                            <field name="message_ids" widget="mail_thread"/>
                        </div>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- explicit Form view definition -->
        <record id="members_details_form_view" model="ir.ui.view">
            <field name="name">members.details.form.view</field>
            <field name="model">team.members</field>
            <field name="arch" type="xml">
                <form string="">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <menuitem name="Teams" id="custom_project.menu_1" parent="project.menu_main_pm"
                  groups="project.group_project_manager"/>


        <!-- actions -->

        <menuitem name="Teams" id="custom_project.menu_1_list" parent="custom_project.menu_1"
                  action="custom_project_template_action" groups="project.group_project_manager"/>


    </data>
</odoo>