        <!-- Project Form View -->
        <record id="custom_project_template_form_view" model="ir.ui.view">
            <field name="name">custom.project.template.form.view</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.edit_project"/>
            <field name="arch" type="xml">
                <!--                                <xpath expr="//notebook/page[last()]" position="after">-->

                <xpath expr="//field[@name='tag_ids']" position="after">
                    <field name="mon"/>
                    <field name="date_start"/>
                    <field name="date"/>
                </xpath>


<!--                <xpath expr="//page[@name='settings']/group/field[@name='partner_id']" position="attributes">-->
<!--                    <attribute name="invisible">1</attribute>-->
<!--                </xpath>-->

                <xpath expr="//field[@name='name']" position="after">
                    <field name="internl_pro_name" placeholder="Internal Project Name"/>
                </xpath>

                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="readonly">1</attribute>
                </xpath>

            </field>
        </record>


        <record id="custom_project_template_tree_view" model="ir.ui.view">
            <field name="name">custom.project.template.tree.view</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.view_project"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="internl_pro_name"/>
                </xpath>
            </field>
        </record>


        <!-- Task Form View -->
        <record id="custom_task_template_form_view2" model="ir.ui.view">
            <field name="name">custom.task.template.form.view</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='project_id']" position="after">
                                        <field name="original_image" widget='image' class="oe_avatar"
                           options='{"preview_image":"medium_image"}'/>

                </xpath>
<!--                <xpath expr="//div[@class='oe_title']" position="inside">-->


<!--                </xpath>-->
                <xpath expr="//field[@name='date_deadline']" position="after">
<!--                    <field name="date_start" string="FW Starting date"/>-->
                    <field name="date_end" string="FW Ending date"/>
                    <field name="traveling_time" string="Target(month of completion)" required="1" force_save="1"/>
                    <field name='team_id' invisible="True"/>
                    <field name='executive_person'/>
                    <field name="user_check" invisible="1"/>
                    <field name='Revenue_bu' readonly="user_check == False"/>
                    <field name='Sales_bu' readonly="user_check == False"/>
                </xpath>
<!--                <xpath expr="//field[@name='planned_date_begin']" position="replace"></xpath>-->
                <field name="planned_date_begin" position="after">
                    <field name="date_end1" string="FW Ending date"/>
                </field>
                <xpath expr="//field[@name='date_deadline']" position="attributes">
                    <attribute name="string">Rev Date</attribute>
                </xpath>


                <!--<xpath expr="//field[@name='estimation_ids']//tree//field[@name='actual_total']" position="attributes">-->
                <!--<attribute name="string">Sample Size</attribute>-->
                <!--</xpath>-->


                <!--<xpath expr="//notebook/page[@name='description_page']/page/group/group/field[@name='planned_hours']" position="attributes">-->
                <!--<attribute name="string">Sample Size</attribute>-->
                <!--</xpath>-->


            </field>
        </record>

