<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_boxed">
        <div class="header o_boxed_header">
            <div class="row mb8">
                <div class="col-xs-6">
                    <img t-if="company.logo" t-att-src="'data:image/png;base64,%s' % to_text(company.logo)"/>
                </div>

                <div class="col-xs-6 text-right mb4">
                    <!--                    <span class="company_address" t-field="company.partner_id"-->
                    <!--                          t-field-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'/>-->
                    <span t-if="company.vat"><t t-esc="company.country_id.vat_label or 'TIN'"/>:
                        <span
                                t-field="company.vat"/>
                    </span>
                </div>
            </div>
        </div>

        <div class="article o_report_layout_boxed">
            <t t-raw="0"/>
        </div>

        <div class="footer o_boxed_footer">
            <div class="text-center">
                <ul class="list-inline">
                    <li t-if="company.phone">Tel:
                        <span t-field="company.phone"/>
                    </li>
                    <li t-if="company.email">Mail:
                        <span t-field="company.email"/>
                    </li>
                    <li t-if="company.website">Web:
                        <span t-field="company.website"/>
                    </li>
                    <li t-if="company.vat"><t t-esc="company.country_id.vat_label or 'TIN'"/>:
                        <span
                                t-field="company.vat"/>
                    </li>
                </ul>
                <div t-field="company.report_footer"/>
                <div>
                    Page:
                    <span class="page"/>
                    /
                    <span class="topage"/>
                </div>
            </div>
        </div>
    </template>

    <template id="external_layout">
        <!-- Multicompany -->
        <t t-if="not o and doc">
            <t t-set="o" t-value="doc"/>
        </t>

        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id.sudo()"/>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"/>
        </t>

        <t t-if="company.external_report_layout_id == 'background'">
            <t t-call="web.external_layout_background">
                <t t-raw="0"/>
            </t>
        </t>
        <t t-if="company.external_report_layout_id == 'boxed'">
            <t t-call="requestioner.external_layout_boxed">
                <t t-raw="0"/>
            </t>
        </t>
        <t t-if="company.external_report_layout_id == 'clean'">
            <t t-call="web.external_layout_clean">
                <t t-raw="0"/>
            </t>
        </t>
        <t t-if="company.external_report_layout_id in (False, 'standard')">
            <t t-call="web.external_layout_standard">
                <t t-raw="0"/>
            </t>
        </t>
    </template>

    <template id="report_purchaseorder_document">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
            <div class="page" style="margin-top:-10px;font-size:11px">
