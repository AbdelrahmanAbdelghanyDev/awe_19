                    <div>
                        <strong>Order Date:</strong>
                        <span t-field="o.date_order" t-options="{'widget': 'date'}"/>
                    </div>
                </div>
                <br/>
                <table class="table table-condensed">
                    <thead style="background-color:#ffd700;">
