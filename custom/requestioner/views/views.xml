<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="methodology_type_form_inherit" model="ir.ui.view">
            <field name="name">methodology_type_form_inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
<!--                <xpath expr="//field[@name='order_line']//list//field[@name='analytic_tag_ids']" position="after">-->
<!--                    <field name="methodology_type_id"/>-->
<!--                </xpath>-->

                <xpath expr="//field[@name='date_approve']" position="attributes">
                    <attribute name="readonly">state == 'done'</attribute>
                </xpath>
            </field>
        </record>

        <record id="purchase_order_form2" model="ir.ui.view">
            <field name="name">purchase.order.form</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_view_invoice']" position="replace">
                    <button type="object" name="action_view_invoice" class="oe_stat_button" icon="fa-pencil-square-o"
                            invisible="state in ('draft','sent','to approve')">
                        <field name="re_invoice_count" widget="statinfo" string="Vendor Bills"/>
                    </button>
                </xpath>

                <xpath expr="//field[@name='incoterm_id']" position="after">
                    <field name="requisitioner" readonly="state == 'done'"/>
                    <field name="re_email" readonly="state == 'done'"/>
                    <field name="re_department" readonly="state == 'done'"/>
                </xpath>

                <xpath expr="//field[@name='payment_term_id']" position="replace">
                    <field name="payment_term_id" options="{'no_open': False, 'no_create': True}"
                           readonly="invoice_status == 'invoiced' or state == 'done'"/>
                </xpath>

                <xpath expr="//field[@name='company_id']" position="before">
                    <field name="payment_method" readonly="state == 'done'"/>
                    <field name="payment_terms_details" readonly="state == 'done'"/>
                    <field name="source_doc" readonly="state == 'done'"/>
                    <field name="amount_to_text" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="client" readonly="state == 'done'"/>
                </xpath>

                <xpath expr="//field[@name='partner_ref']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//list/field[@name='date_planned']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//list/field[@name='price_unit']" position="replace">
                    <field name="product_qty" string="Sample Size"/>
                    <field name="price_unit" string="CPI" readonly="invoice_lines != []"/>
                </xpath>

                <xpath expr="//group/group/div/field[@name='date_planned']" position="replace">
                    <field name="date_planned" required="0" string="asd"
                           readonly="state not in ('draft', 'sent')"/>
                </xpath>
            </field>
        </record>

        <!-- Inherit Form View to Modify it -->
        <record id="purchase_order_form_readonly" model="ir.ui.view">
            <field name="name">purchase.order.form.readonly</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase_requisition.purchase_order_form_inherit"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='requisition_id']" position="attributes">
                    <attribute name="readonly">state == 'done'</attribute>
                </xpath>

                <xpath expr="//field[@name='company_id']" position="attributes">
                    <attribute name="readonly">state == 'done'</attribute>
                </xpath>

                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="readonly">state == 'done'</attribute>
                </xpath>

                <xpath expr="//field[@name='invoice_status']" position="attributes">
                    <attribute name="readonly">state == 'done'</attribute>
                </xpath>

                <xpath expr="//field[@name='origin']" position="attributes">
                    <attribute name="readonly">state == 'done'</attribute>
                </xpath>

                <xpath expr="//field[@name='payment_term_id']" position="attributes">
                    <attribute name="readonly">state == 'done'</attribute>
                </xpath>

                <xpath expr="//field[@name='fiscal_position_id']" position="attributes">
                    <attribute name="readonly">state == 'done'</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>