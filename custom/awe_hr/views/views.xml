<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="hr_employee_from_view" model="ir.ui.view">
            <field name="name">hr_employee_from_view</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">

                <xpath expr="//page[@name='personal_information']/group/group[3]" position="after">
                    <group string="Resignation">
                        <field name="resignation_date"/>
                        <field name="reason"/>

                    </group>
                </xpath>
                <xpath expr="//field[@name='user_id']" position="replace">
                    <field name="user_id" string="Related User"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>