<odoo>
  <data>
    <record id="purchase_order_cancel" model="res.groups">
        <field name="name">Purchase Order Cancel</field>
    </record>

      <!-- Inherit Form View to Modify it -->
      <record id="purchase_order_cancel_group" model="ir.ui.view">
          <field name="name">purchase.order.cancel.group</field>
          <field name="model">purchase.order</field>
          <field name="inherit_id" ref="purchase.purchase_order_form"/>
          <field name="arch" type="xml">

              <xpath expr="//button[@name='button_cancel']" position="before">
                  <field name="cancel_visibility" invisible="1"/>
              </xpath>

              <xpath expr="//button[@name='button_cancel']" position="replace">
                  <button name="button_cancel" attrs="{'invisible': [('cancel_visibility', '=', True)]}" string="Cancel" type="object"/>
              </xpath>

<!--              <xpath expr="//button[@name='button_cancel']" position="attributes">-->
<!--                  <attribute name="attrs">{'invisible': [('cancel_visibility', '=', True)]}</attribute>-->
<!--              </xpath>-->

          </field>
      </record>
  </data>
</odoo>