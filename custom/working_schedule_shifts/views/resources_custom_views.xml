    <record model="ir.ui.view" id="calendar_month_shifts_form_view">
            <field name="name">calendar.month.shifts</field>
            <field name="model">calendar.month</field>
            <field name="arch" type="xml">
                <form string="Working Schedule Shifts">
                    <sheet>
                        <group>
                            <field name="month" widget="selection"/>
                            <field name="resource_calendar_id" invisible="1"/>
                            <field name="is_created" invisible="1"/>
                            <field name="shift_ids">
                                <list editable="bottom" create="0" delete="0"><!--attrs="{'invisible': [('is_created','=', False)]}">-->
                                    <field name="day" readonly="1"/>
                                    <field name="employees_ids" widget="many2many_tags" editable="1"/>
                                </list>
                            </field>
                            <footer>
                                <button string="Save" class="btn-default" special="save"/>
                                <button string="Cancel" class="btn-default" special="cancel"/>
                            </footer>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    <record model="ir.ui.view" id="calendar_month_day_form_view">
            <field name="name">calendar.month.day</field>
            <field name="model">calendar.month.day</field>
            <field name="arch" type="xml">
                <form string="Working Schedule Shifts">
                    <sheet>
                        <group>
                            <field name="day"/>
                            <field name="employees_ids"/>
                            <field name="calendar_month_id" invisible="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
    </record>
    <record id="action_calendar_month_day" model="ir.actions.act_window">
        <field name="name">Calendar Month</field>
        <field name="res_model">calendar.month</field>
        <field name="view_mode">list,form</field>
    </record>
    </data>
</odoo>