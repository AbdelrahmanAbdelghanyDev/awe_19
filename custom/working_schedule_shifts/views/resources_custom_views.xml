<odoo>
    <data>
    <record id="resource_calendar_form2" model="ir.ui.view">
        <field name="name">resource.calendar.form2</field>
        <field name="model">resource.calendar</field>
        <field name="inherit_id" ref="resource.resource_calendar_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Shifts">
                    <field name="month_ids">
                        <list editable="bottom">
                            <field name="month"/>
                            <field name="is_created" invisible="1"/>
                            <button name="button_day_details" string="Details" type="object" invisible="is_created == False"/>
                        </list>
                    </field>
                </page>
                <!--<page string="Shifts">-->

                <!--</page>-->
            </xpath>
        </field>
    </record>
