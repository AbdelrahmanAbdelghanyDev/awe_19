<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="One2ManySelectable" t-inherit="web.X2ManyField" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('o_x2m_control_panel')]" position="before">
            <div class="cf_button_array mb-2">
                <button type="button"
                        class="btn btn-primary me-1"
                        t-on-click="onBulkVerify">
                    Send to WareHouse
                </button>
                <button type="button"
                        class="btn btn-primary me-1"
                        t-on-click="onToAccountant">
                    Send to Accountant
                </button>
                <button type="button"
                        class="btn btn-primary me-1"
                        t-on-click="onToExpense">
                    Create Expense
                </button>
            </div>
        </xpath>
    </t>

</templates>