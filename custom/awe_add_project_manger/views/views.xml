<odoo>
    <data>
        <record id="custom_work_country_id_form_view2" model="ir.ui.view">
            <field name="name">Work country</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='sale_info']" position="inside">
                    <field name="project_manager_id"  readonly="state == 'done'"/>
                </xpath>

                <xpath expr="//button[@name='action_view_invoice']" position="attributes">
                    <attribute name="groups">awe_add_project_manger.group_invoice_view</attribute>
                </xpath>
            </field>
        </record>

        <record id="group_invoice_view" model="res.groups">
            <field name="name">Invoice View Access</field>
        </record>


        <record id="res_users_form_view_inherited" model="ir.ui.view">
            <field name="name">res.users.form.inherited</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group//field[@name='partner_id']" position="after">
                    <field name="is_project_manager"/>
                </xpath>
            </field>
        </record>


    </data>
</odoo>

