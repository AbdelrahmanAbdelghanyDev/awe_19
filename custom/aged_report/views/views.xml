<odoo>
    <data>
        <record id="aged_report_sale_order_line" model="ir.ui.view">
            <field name="name">Aged Report</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page/field/list/field[@name='price_total']" position="after">
                    <field name="is_revenue_button_clicked" invisible="1"/>
                    <field name="task_status"  invisible="1"/>
                </xpath>
            </field>
        </record>
        <record id="aged_report_invoice_order_line" model="ir.ui.view">
            <field name="name">Aged Report</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="after">
<!--                    <field name="open_date"/>-->
                    <field name="invoice_open_days"/>
                </xpath>
                <xpath expr="//page/field/list/field[@name='price_subtotal']" position="after">
                    <field name="is_revenue_button_clicked"/>
                    <field name="task_status"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>