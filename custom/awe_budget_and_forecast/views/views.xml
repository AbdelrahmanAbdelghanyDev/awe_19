<odoo>

    <!-- Budget and Forecast Tree View -->
    <record id="budget_and_forecast_tree_view" model="ir.ui.view">
        <field name="name">budget_and_forecast_tree_view</field>
        <field name="model">budget.forecast</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- Budget and Forecast Form View -->
    <record id="budget_and_forecast_form_view" model="ir.ui.view">
        <field name="name">budget_and_forecast_form_view</field>
        <field name="model">budget.forecast</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Approve"
                            type="object"
                            name="action_approve"
                            class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button string="Sales BU - Revenue BU / Totals"
                            type="object"
                            name="get_totals"
                            class="btn-primary"/>
                    <button string="Generate Comparison"
                            type="object"
                            name="generate_comparison"
                            class="btn-primary"
                            attrs="{'invisible': [('comparison_ids', '=', [])]}"/>
                    <button string="Reset to Draft"
                            type="object"
                            name="action_reset_to_draft"
                            attrs="{'invisible': [('state', '!=', 'approved')]}"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_forecast_lines"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list">
                            <field name="budget_forecast_line_count" widget="statinfo" string="Lines"/>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name"  attrs="{'readonly': [('state', '=', 'approved')]}"/>
                            <field name="comparison_ids" widget="many2many_tags"  attrs="{'readonly': [('state', '=', 'approved')]}"/>
                            <field name="comparison_count" invisible="1"/>
                            <!--                            <field name="partner_id_domain" invisible="1"/>-->
                        </group>
                        <group>
                            <field name="type"  attrs="{'readonly': [('state', '=', 'approved')]}"/>
                            <field name="year"  attrs="{'readonly': [('state', '=', 'approved')]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="budget_forecast_line_ids"
                                   attrs="{'readonly': [('state', '=', 'approved')]}"
                                   options="{'no_open': True}">
                                <tree editable="bottom">
                                    <!-- Static Fields -->
                                    <field name="partner_id_domain" invisible="1"/>
                                    <field name="partner_id" domain="partner_id_domain" optional="show"/>
                                    <field name="label" optional="show"/>
                                    <field name="create_uid" optional="show"/>
                                    <field name="sector_id" optional="show"/>
                                    <field name="project_type" optional="show"/>
                                    <field name="type" optional="show"/>
                                    <field name="sales_bu_id" optional="show"/>
                                    <field name="rev_bu_id" optional="show"/>

                                    <!-- Parent Metrics -->
                                    <field name="sales" optional="show"/>
                                    <field name="rev" optional="show"/>
                                    <field name="gm" optional="show"/>
                                    <field name="rev_gm" optional="show"/>
                                    <field name="secured_rev" optional="show"/>
                                    <field name="secured_gm" optional="show"/>

                                </tree>
                            </field>
                        </page>
                        <page string="Sales BU - Revenue BU / Totals">
                            <field name="sales_bu_total_ids" attrs="{'readonly': 1}" options="{'no_open': True}">
                                <tree create="0" delete="0">
                                    <field name="sales_bu_id"/>

                                    <field name="sales"/>
                                    <field name="rev"/>
                                    <field name="gm"/>
                                    <field name="rev_gm"/>
                                </tree>
                            </field>
                            <field name="rev_bu_total_ids" attrs="{'readonly': 1}" options="{'no_open': True}">
                                <tree create="0" delete="0">
                                    <field name="rev_bu_id"/>

                                    <field name="sales"/>
                                    <field name="rev"/>
                                    <field name="gm"/>
                                    <field name="rev_gm"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Comparison Results"
                              attrs="{'invisible': [('comparison_ids', '=', [])]}">
                            <field name="comparison_line_ids" attrs="{'readonly': 1}" options="{'no_open': True}">
                                <tree create="0" delete="0">
                                    <!-- Static Fields -->
                                    <!--                                    <field name="partner_id"/>-->
                                    <field name="label"/>
                                    <!--                                    <field name="create_uid"/>-->
                                    <!--                                    <field name="sector_id"/>-->
                                    <!--                                    <field name="project_type"/>-->
                                    <field name="type"/>
                                    <field name="sales_bu_id"/>
                                    <field name="rev_bu_id"/>
                                    <field name="comparison_count" invisible="1"/>

                                    <!-- Quarter 1 Metrics -->
                                    <field name="q1_sales"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 1)]}"/>
                                    <field name="q1_rev"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 1)]}"/>
                                    <field name="q1_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 1)]}"/>
                                    <field name="q1_rev_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 1)]}"/>

                                    <!-- Quarter 2 Metrics -->
                                    <field name="q2_sales"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 2)]}"/>
                                    <field name="q2_rev"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 2)]}"/>
                                    <field name="q2_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 2)]}"/>
                                    <field name="q2_rev_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 2)]}"/>

                                    <!-- Quarter 3 Metrics -->
                                    <field name="q3_sales"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 3)]}"/>
                                    <field name="q3_rev"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 3)]}"/>
                                    <field name="q3_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 3)]}"/>
                                    <field name="q3_rev_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 3)]}"/>

                                    <!-- Quarter 4 Metrics -->
                                    <field name="q4_sales"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 4)]}"/>
                                    <field name="q4_rev"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 4)]}"/>
                                    <field name="q4_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 4)]}"/>
                                    <field name="q4_rev_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 4)]}"/>

                                    <!-- Quarter 5 Metrics -->
                                    <field name="q5_sales"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 5)]}"/>
                                    <field name="q5_rev"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 5)]}"/>
                                    <field name="q5_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 5)]}"/>
                                    <field name="q5_rev_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 5)]}"/>

                                    <!-- Quarter 6 Metrics -->
                                    <field name="q6_sales"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 6)]}"/>
                                    <field name="q6_rev"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 6)]}"/>
                                    <field name="q6_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 6)]}"/>
                                    <field name="q6_rev_gm"
                                           attrs="{'column_invisible': [('parent.comparison_count', '&lt;', 6)]}"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_budget_forecast_line_tree" model="ir.ui.view">
        <field name="name">budget.forecast.line.tree</field>
        <field name="model">budget.forecast.line</field>
        <field name="arch" type="xml">
            <tree editable="bottom" create="0">
                <field name="partner_id_domain" invisible="1"/>
                <field name="partner_id" domain="partner_id_domain" optional="show"/>
                <field name="label" optional="show"/>
                <field name="create_uid" optional="show"/>
                <field name="sector_id" optional="show"/>
                <field name="project_type" optional="show"/>
                <field name="type" optional="show"/>
                <field name="sales_bu_id" optional="show"/>
                <field name="rev_bu_id" optional="show"/>

                <!-- Parent Metrics -->
                <field name="sales" optional="show"/>
                <field name="rev" optional="show"/>
                <field name="gm" optional="show"/>
                <field name="rev_gm" optional="show"/>
                <field name="secured_rev" optional="show"/>
                <field name="secured_gm" optional="show"/>

            </tree>
        </field>
    </record>


    <record id="action_budget_and_forecast" model="ir.actions.act_window">
        <field name="name">Budget and Forecast</field>
        <field name="res_model">budget.forecast</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_budget_and_forecast" name="Budget &amp; Forecast" action="action_budget_and_forecast"
              web_icon="awe_budget_and_forecast,static/icons/forecasting.png"/>

</odoo>