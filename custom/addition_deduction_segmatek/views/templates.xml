<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- =======================
             Structure Types
        ======================= -->
        <record id="structure_type_employee" model="hr.payroll.structure.type">
            <field name="name">Employee</field>
            <field name="country_id" eval="False"/>
        </record>

        <record id="structure_type_worker" model="hr.payroll.structure.type">
            <field name="name">Worker</field>
            <field name="country_id" eval="False"/>
        </record>

        <!-- =======================
             Addition Structure
        ======================= -->
        <record id="structure_addition_001" model="hr.payroll.structure">
            <field name="name">Addition</field>
            <field name="type_id" ref="hr.structure_type_employee"/>
            <field name="country_id" eval="False"/>
        </record>

        <record id="hr_rule_addition" model="hr.salary.rule">
            <field name="name">Addition</field>
            <field name="sequence" eval="12"/>
            <field name="code">ADDITION</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="struct_id" ref="structure_addition_001"/>
            <field name="amount_python_compute">
result = payslip.env['hr.payslip'].calculate_addition(payslip.id)
            </field>
        </record>

        <record id="structure_additions" model="hr.payroll.structure">
            <field name="code">SOVERs</field>
            <field name="name">Addition structure</field>
            <field eval="[(6, 0, [ref('hr_rule_addition')])]" name="rule_ids"/>
            <field name="type_id" ref="hr.structure_type_employee"/>
        </record>

        <!-- =======================
             Deduction Structure
        ======================= -->
        <record id="hr_rule_mydeduction" model="hr.salary.rule">
            <field name="name">Deduction</field>
            <field name="sequence" eval="120"/>
            <field name="code">DEDUCTION</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="struct_id" ref="structure_additions"/>
            <field name="amount_python_compute">
result = payslip.env['hr.payslip'].calculate_deduction(payslip.id)
            </field>
        </record>

        <record id="structure_deductions" model="hr.payroll.structure">
            <field name="code">DEDUCS</field>
            <field name="name">Deduction structure</field>
            <field eval="[(6, 0, [ref('hr_rule_mydeduction')])]" name="rule_ids"/>
            <field name="type_id" ref="hr.structure_type_employee"/>
        </record>

    </data>
</odoo>