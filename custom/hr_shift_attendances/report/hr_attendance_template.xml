    <!-- template use to render a Registration Badge -->
    <template id="hr_attendance_template">
        <t t-call="web.external_layout">

                <div class="container">
                    <div class="page">
                        <div class="row" style="border-top:1px solid black;">
                            <table class="table">
                                <thead style="border:1px solid black">
                                   <tr style="border:1px solid black">
                                       <th style="border:1px solid black">Employee</th>
                                       <th style="border:1px solid black">Date</th>
                                       <th style="border:1px solid black">Check In</th>
                                       <th style="border:1px solid black">Check Out</th>
                                       <th style="border:1px solid black">Total Working Time</th>
                                       <th style="border:1px solid black">Normal Working Time</th>
                                       <th style="border:1px solid black">Late In</th>
                                       <th style="border:1px solid black">Early Out</th>
                                       <th style="border:1px solid black">Remarks</th>
                                   </tr>
                                </thead>
                                <!--<t t-foreach="o.line_ids" t-as="x">-->
                                <t t-foreach="docs" t-as="o">
                                    <tr style="border-bottom:1px solid black">
                                        <td style="border:1px solid black"><div t-field="o.employee_id.name"/></td>
                                        <td style="border:1px solid black"><div t-field="o.custom_date"/></td>
                                        <td style="border:1px solid black"><div t-field="o.custom_in"/></td>
                                        <td style="border:1px solid black"><div t-field="o.custom_out"/></td>
                                        <td style="border:1px solid black"><div t-field="o.working_hours_per_day"/></td>
                                        <td style="border:1px solid black"><div t-field="o.custom_normal_hours"/></td>
                                        <td style="border:1px solid black"><div t-field="o.is_late_time"/></td>
                                        <td style="border:1px solid black"><div t-field="o.is_early_time"/></td>
                                        <td style="border:1px solid black"><div t-field="o.display_remarks"/></td>
                                    </tr>
                                </t>
