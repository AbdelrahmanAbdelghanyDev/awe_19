        <!-- Inherit Form View to Modify it -->
        <record id="view_inherit_employee_domain_form" model="ir.ui.view">
            <field name="name">view.inherit.employee.domain.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr_holidays.view_employee_form_leave_inherit"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='%(hr.plan_wizard_action)d']" position="replace">
                    <button name="get_employee_id"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-calendar"
                            attrs="{'invisible': [('show_leaves','=', False)]}"
                            groups="base.group_user"
                            help="Remaining leaves">
                        <field string="Leaves Left" name="leaves_count" widget="statinfo"/>
                    </button>

                </xpath>

            </field>
        </record>

