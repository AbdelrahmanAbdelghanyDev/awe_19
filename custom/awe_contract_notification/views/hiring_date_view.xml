<odoo>
    <data>
        <record id="employee_hiring_date_view" model="ir.ui.view">
            <field name="name">employee_hiring_date_view</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='work_location_id']" position="after">
                    <group string="Hiring Date">
                        <field name="hiring_date"/>
                    </group>

                    <group string="Probation Date">
                        <field name="probation_date"/>
                    </group>
                </xpath>

            </field>
        </record>

