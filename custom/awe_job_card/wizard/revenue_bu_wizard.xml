<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--        Revenue BU Wizard Form View-->
        <record id="revenue_bu_wizard_form_view" model="ir.ui.view">
            <field name="name">revenue_bu_wizard_form_view</field>
            <field name="model">revenue.bu.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
<!--                            <field name="analytic_tag_ids" widget="many2many_tags"/>-->
                            <field name="month_ids" widget="many2many_tags"
                                   options="{'no_create':True,'no_create_edit':True}"/>
                            <field name="year"/>
                        </group>
                    </sheet>
                    <footer>
<!--                        <button name="generate_revenue_bu" string="Generate" type="object" class="oe_highlight"/>-->
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


    </data>
</odoo>