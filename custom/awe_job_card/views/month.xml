<odoo>
    <data>

        <!-- Month Tree View -->
        <record id="res_month_tree_view" model="ir.ui.view">
            <field name="name">res_month_tree_view</field>
            <field name="model">res.month</field>
            <field name="arch" type="xml">
                <list string="Months" editable="bottom">
                    <field name="name"/>
                    <field name="num" invisible="1"/>
                </list>
            </field>
        </record>

        <!--        Actions-->
        <record id="action_month" model="ir.actions.act_window">
            <field name="name">Months</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.month</field>
            <field name="view_mode">list</field>
        </record>

        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="menu_job_card_config" name="Configuration"
                  parent="awe_job_card.menu_job_card_root" groups="base.group_system"/>
        <menuitem id="menu_month" name="Months"
                  parent="awe_job_card.menu_job_card_config"
                  action="action_month"/>

    </data>
</odoo>