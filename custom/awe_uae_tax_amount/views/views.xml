<odoo>
    <data>

        <record id="uae_tax_amount" model="ir.ui.view">
            <field name="name">uae_tax_amount</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page[@id='invoice_tab']" position="inside">
                    <field name="is_uae" invisible="1"/>
                </xpath>
                <xpath expr="//notebook/page[@id='invoice_tab']/field[@name='invoice_line_ids']/list/field[@name='tax_ids']"
                       position="after">
                    <field name="tax_amount" column_invisible="parent.is_uae == False"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>