<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="view_move_form_inh_sale_purchase" model="ir.ui.view">
            <field name="name">account.move.inh.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

                <xpath expr="//div[@class='o_attachment_preview']" position="replace">

                </xpath>
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="seq_name" invisible="1"/>
                    <field name="task_state" readonly="1" invisible="1"/>
                    <field name="is_revenue_button_clicked" readonly="1" invisible="1"/>

                    <field name="po_num" placeholder="e.g. PO231197"/>
                    <field name="gr_num" placeholder="e.g. GR231197"/>
                    <field name="vendor_num" placeholder="e.g. V2231197"/>
                    <field name="official_name" placeholder="The Official Name"/>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="seq_name" invisible="1"/>
                    <field name="official_name" placeholder="The Official Name"/>
                </xpath>

                <xpath expr="//field[@name='invoice_line_ids']" position="after">
                    <label for="custom_payment_terms"/>
                    <field name="custom_payment_terms"/>
                </xpath>

            </field>
        </record>
