<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--        ٠ ١ ٢ ٣ ٤ ٥ ٦ ٧ ٨ ٩ -->
        <template id="report_ksa_invoice_arabic">

            <t t-call="web.external_layout">

                <t t-set="o" t-value="o.with_context(lang='ar')"/>
                <div class="page" style="text-align:right;font-size:11px;" dir="rtl">
                    <div>
                        <div align="left">
                                <img t-if="o.l10n_sa_qr_code_str" t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s'%('QR', quote_plus(o.l10n_sa_qr_code_str), 150, 150)"/>                        </div>
                        <br/>

                        <h5 class="text-center" dir="rtl">

                            <b>
                                <span t-field="o.company_id.company_name_ar"/>
                            </b>

                        </h5>
                        <br/>
                    </div>
                    <span>
                        <span t-field="o.company_id.address_ar"/>
                    </span>
                    <br/>
                    <span>
                        <span t-field="o.company_id.mobile_ar"/>
                    </span>
                    <br/>
                    <!--                    <p>-->
                    <!--                        <span t-field="o.company_id.tax_number_ar"/>-->
                    <!--                    </p>-->
                    <span>
                        <a t-attf-href="http://www.aweresearch.com">www.aweresearch.com</a>
                    </span>
                    <br/>
                    <span>رقم السجل التجاري:
                        <span t-field="o.company_id.tax_number_ar"/>
                    </span>
                    <br/>
                    <span style="white-space: nowrap;">رقم التسجيل في ضريبة القيمة المضافة:
                        <span t-field="o.company_id.tax_number2_ar"/>
                    </span>
                    <br/>
                    <span>رقم الملف:
                        <span t-field="o.company_id.file_number"/>
                    </span>
                    <br/>
                    <div>


                    </div>

                    <div class="row" dir="rtl">
                        <div class="col-6" dir="rtl">
                            <div>
                                <span>التاريخ :</span>
                                <span t-esc="o.invoice_date_time"
                                      t-options='{"widget": "datetime","format": "dd-MM-yyyy HH:mm:ss"}'/>
                            </div>
                            <div>
                                <span>رقم الفاتورة :</span>
                                <span t-field="o.name"/>

                            </div>
                            <div>
                                <span>رقم المشروع :</span>
                                <span t-field="o.invoice_origin"/>

                            </div>
                            <div>
                                <span>رقم أمر الشراء :</span>
                                <span t-field="o.po_num"/>

                            </div>
                            <div>
                                <span>رقم المورد :</span>
                                <span t-field="o.vendor_num"/>

                            </div>
                        </div>
                        <div class="col-6">
                            <strong>إلى :</strong>
                            <br/>
                            <div>
                                <address t-field="o.partner_id"
                                         t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}'/>
                            </div>
                            <div t-if="o.partner_id.cr_numb">
                                <span>رقم السجل التجاري :</span>
                                <span t-field="o.partner_id.cr_numb"/>

                            </div>
                            <div t-if="o.partner_id.vat">
                                <span>رقم التسجيل بضريبة القيمة المضافة :</span>
                                <span t-field="o.partner_id.vat"/>

                            </div>
                            <div>

                            </div>
                            <div t-if="o.partner_id.phone">
                                <span>رقم التليفون :</span>
                                <span t-field="o.partner_id.phone"/>

                            </div>
                            <div t-if="o.partner_id.child_ids">
                                <span>موجهة إلى :</span>
                                <div t-foreach="o.partner_id.child_ids" t-as="l">
                                    <span t-field="l.name"/>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <!--                    <div style="float:left; margin-top:5%;">-->
                <!--                        -->
                <!--                    </div>-->
                <!--                    <div class="row" style="margin-top:5%;">-->
                <!--                        <div>-->
                <!--                            <span t-field="o.invoice_date"/>-->
                <!--                            <span>: التاريخ</span>-->
                <!--                        </div>-->
                <!--                        <div>-->
                <!--                            <span t-field="o.name"/>-->
                <!--                            <span>: رقم الفاتورة</span>-->
                <!--                        </div>-->
                <!--                        <div>-->
                <!--                            <span t-field="o.invoice_origin"/>-->
                <!--                            <span>: رقم المشروع</span>-->
                <!--                        </div>-->
                <!--                        <div>-->
                <!--                            <span t-field="o.po_num"/>-->
                <!--                            <span>: رقم أمر الشراء</span>-->
                <!--                        </div>-->
                <!--                        <div>-->
                <!--                            <span t-field="o.vendor_num"/>-->
                <!--                            <span>: رقم المورد</span>-->
                <!--                        </div>-->
                <!--                    </div>-->

                <!-- Is there a discount on at least one line? -->
                <t t-set="display_discount" t-value="any([l.discount for l in o.invoice_line_ids])"/>
                <h4 style="text-align:center;" t-if="o.move_type in ('out_invoice','in_invoice')">فاتورة ضريبية</h4>
                <h4 style="text-align:center;" t-if="o.move_type in ('out_refund','in_refund')">اشعار دائن</h4>
                <table class="table table-condensed" name="invoice_line_table" style="margin-top:2%;" dir="rtl">
                    <thead>
                        <tr>
                            <th class="text-right">البيان</th>
                            <th class="text-right">الكمية</th>
                            <th class="text-right">سعر الوحدة</th>
                            <th t-if="display_discount" class="text-right">Disc.(%)</th>
                            <th class="text-center">اجمالى قبل الضريبة</th>
                            <th class="text-center">الضريبة</th>
                            <th class="text-center">إجمالي الضريبة</th>

                            <th class="text-center">إجمالي السعر بعد الضريبة</th>
                            <!--                                <th class="hidden">Source Document</th>-->
                        </tr>
                    </thead>
                    <tbody class="invoice_tbody">
                        <tr t-foreach="o.invoice_line_ids" t-as="l">

                            <td class="text-right" style="background-color:white;">
                                <span t-field="l.name"/>
                            </td>
                            <td class="text-right">
                                <span t-field="l.quantity"/>
                                <span t-field="l.uom_id" groups="product.group_uom"/>
                            </td>
                            <td class="text-right">
                                <t t-set="tmp" t-value="str(l.price_unit)"/>
                                <span t-if="tmp[::-1].find('.') == 1" t-esc="tmp + '0'"/>
                                <span t-if="tmp[::-1].find('.') == 2" t-esc="tmp"/>
                                <span t-if="tmp[::-1].find('.') > 2" t-esc="tmp[:tmp.find('.') + 3]"/>
                            </td>
                            <td t-if="display_discount" class="text-right">
                                <span t-field="l.discount"/>
                            </td>
                            <td class="text-center" id="subtotal">
                                <span t-field="l.price_subtotal"
                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                            <td>
                                <span t-foreach="l.tax_ids" t-as="x" class="text-right">
                                    <span t-field="x.name"/>
                                    <br/>
                                </span>
                            </td>

                            <td class="text-center">
                                <span t-esc=" l.price_total - l.price_subtotal"
                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>

                            <td class="text-center" id="total" style="background-color:Gainsboro;">
                                <span t-field="l.price_total"
                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>


                            <!--                                <td class="hidden">-->
                            <!--                                    <span t-field="l.origin"/>-->
                            <!--                                </td>-->

                        </tr>
                    </tbody>
                </table>
                <div class="clearfix">
                    <div id="total" class="row" dir="rtl">
                        <div t-attf-class="#{'col-6' if report_type != 'html' else 'col-sm-7 col-md-6'} ml-auto">
                            <table class="table table-sm" style="page-break-inside: avoid;">

                                <!--Tax totals-->
                                <t t-set="tax_totals" t-value="json.loads(o.tax_totals_json)"/>
                                <t t-call="awe_official_name.document_tax_totals_ar"/>

                            </table>
                        </div>
                    </div>
                    <div class="row" style="margin-right:5px;">
                        <strong>
                            <u>التوقيع المعتمد</u>
                        </strong>
                    </div>
                </div>
                <br/>
                <br/>
                <br/>
                <p t-if="o.fiscal_position_id.note">
                    <span t-field="o.fiscal_position_id.note"/>
                </p>
                <div class="pull-left" style="border:1px solid black;padding:5px;width:45%">
                    <strong>
                        <u>شروط الدفع</u>
                    </strong>
                    <p t-field="o.custom_payment_terms"/>
                </div>
                <div class="pull-left"
                     style="border:1px solid black;padding:5px;width:45%;clear: both;margin-top:5px;">
                    <span>: يمكنك الدفع بالتحويل المباشر إلى</span>
                    <p class="text-left">
                        <br/>
                        <strong dir="ltr">Awesome M Research‬</strong>
                        <br/>
                        <span>Account No:
                            <span t-field="o.company_id.Account_No"/>
                            <!--                                895-046746-001-->
                        </span>
                        <br/>
                        <span>IBAN(
                            <span t-field="o.company_id.IBAN_ksa"/>
                            <!--                                SA6145000000895046746001-->
                            )
                        </span>
                        <br/>
                        <span>SWIFT CODE: (
                            <span t-field="o.company_id.SHB_SWIFT_CODE"/>
                            <!--                                SABBSARI-->
                            )
                        </span>
                        <!--                            account 2 -->
                        <span t-if="o.company_id.Account_No2">Account No 2:
                            <span t-field="o.company_id.Account_No2"/>
                            <!--                                895-046746-001-->
                        </span>
                        <br/>
                        <span t-if="o.company_id.IBAN_ksa2">IBAN 2(
                            <span t-field="o.company_id.IBAN_ksa2"/>
                            <!--                                SA6145000000895046746001-->
                            )
                        </span>
                        <br/>
                        <span t-if="o.company_id.SHB_SWIFT_CODE2">SWIFT CODE 2: (
                            <span t-field="o.company_id.SHB_SWIFT_CODE2"/>
                            <!--                                SABBSARI-->
                            )
                        </span>
                        <br/>
                        <span>SHB</span>
                        <span>PO. BOX
                            <span t-field="o.company_id.PO_Box"/>
                        </span>
                        <br/>
                        <span>Jeddah, Saudia Arabia 21411</span>
                    </p>
                </div>


            </t>
        </template>

        <template id="awe_ksa_invoice_arabic">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <!--                                    <xpath expr="//t[@t-set='address']" position="replace">-->
                    <!--                </xpath>-->
                    <t t-call="awe_official_name.report_ksa_invoice_arabic" t-lang="ar"/>
                </t>
            </t>
        </template>
        <template id="document_tax_totals_ar">
            <!--
                Generic template to display tax totals in pdf reports.
                Used by invoices, SO and PO.

                ARGUMENTS:
                - tax_totals: dict in the form generated by account.move's _get_tax_totals.
            -->
            <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                <tr class="border-black o_subtotal">
                    <td>الإجمالي بدون ضريبة</td>

                    <td class="text-right">
                        <span
                                t-att-class="oe_subtotal_footer_separator"
                                t-esc="subtotal['formatted_amount']"
                        />
                    </td>
                </tr>
                <tr class="border-black o_subtotal">
                    <td>ضريبة القيمة المضافة</td>

                    <td class="text-right">
                        <span
                                t-att-class="oe_subtotal_footer_separator"
                                t-esc="o.amount_tax"
                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                        />
                    </td>
                </tr>

                <!--                <t t-set="subtotal_to_show" t-value="subtotal['name']"/>-->
                <!--                <t t-call="account.tax_groups_totals"/>-->
            </t>

            <!--Total amount with all taxes-->
            <tr>
                <td>
                    <strong>الإجمالي بالضريبة</strong>
                </td>
                <td class="text-right">
                    <span t-esc="tax_totals['formatted_amount_total']"/>
                </td>
            </tr>
            <tr>
                <td>
                    <strong>إجمالي المستحق</strong>
                </td>
                <td class="text-right">
                    <span t-esc="o.currency_id.ar_amount_to_text(o.amount_total)"/>

                </td>
            </tr>
            <!--            <tr>-->
            <!--                <td>-->
            <!--                    <strong>Total Due</strong>-->
            <!--                </td>-->
            <!--                <td class="text-right">-->
            <!--                    <span t-esc="o.currency_id.en_amount_to_text(o.amount_total)"/>-->

            <!--                </td>-->
            <!--            </tr>-->
        </template>

    </data>
</odoo>
